{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "MOS.ExcelGrading.API.Middlewares": "Information"
        }
    },
    "AllowedHosts": "*",
    "AppMode": "local",
    "MongoDbSettings": {
        "ConnectionString": "",
        "DatabaseName": "MOS",
        "UsersCollectionName": "Users",
        "SchoolsCollectionName": "Schools",
        "ClassesCollectionName": "Classes"
    },
    "Cors": {
        "Profiles": {
            "local": [
                "http://localhost:5173",
                "https://localhost:5173"
            ],
            "production": [
                "https://mos-grader-app.info.vn"
            ],
            "deploy": [
                "https://mos-grader-app.info.vn"
            ]
        },
        "AllowedOrigins": [
            "http://localhost:5173",
            "https://localhost:5173"
        ]
    },
    "JwtSettings": {
        "SecretKey": "your-super-secret-key-at-least-32-characters-long",
        "Issuer": "MOS.ExcelGrading",
        "Audience": "MOS.ExcelGrading.Users",
        "ExpiryMinutes": 60,
        "RefreshTokenExpiryDays": 7
    },
    "GoogleAuth": {
        "ClientId": ""
    },
    "GoogleSheets": {
        "Enabled": true,
        "ApplicationName": "MOS Grader",
        "ServiceAccountJson": "",
        "ServiceAccountJsonPath": "",
        "DefaultSpreadsheetId": ""
    },
    "Redis": {
        "Enabled": false,
        "ConnectionString": "",
        "InstanceName": "mos-grader",
        "SchoolsTtlSeconds": 60,
        "ClassesBySchoolTtlSeconds": 60,
        "TeachersTtlSeconds": 60
    },
    "AgentApi": {
        "AllowAnonymousInDevelopment": false
    }
}
